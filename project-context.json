      "icon": "BarChart2",
      "section": "Sales",
      "description": "Week-over-week bar charts color-coded by month, day-of-week performance grid, weekly trend line, 5 key stats"
    },
    {
      "id": "returns",
      "label": "Returns",
      "icon": "RotateCcw",
      "section": "Operations",
      "description": "Returns bar chart with 2.5% target line, Monthly Returns Revenue table, Return Rate trend line chart"
    },
    {
      "id": "payments",
      "label": "Payment Mix",
      "icon": "CreditCard",
      "section": "Operations",
      "description": "Stacked bar chart (cash vs card), Card % trend line, Payment Mix donut, monthly detail table, Loyalty Card indicator"
    },
    {
      "id": "forecast",
      "label": "Forecast",
      "icon": "BarChart3",
      "section": "Strategy",
      "description": "9-month forecast view (6 actual + 3 projected), Base/Bear/Bull scenarios for Apr-Jun, Cumulative Projection area chart"
    },
    {
      "id": "simulator",
      "label": "What-If",
      "icon": "Zap",
      "section": "Strategy",
      "description": "6 scenario cards (rent increase, return reduction, staff addition, revenue growth, marketing cut, foot traffic doubling) with toggle, ComposedChart comparison, net impact scorecard"
    },
    {
      "id": "gaps",
      "label": "Data Gaps",
      "icon": "Database",
      "section": "Strategy",
      "description": "Data Completeness Score (45%), RadarChart visualization, What We Have cards, Missing Data Priority Matrix (15 gaps), Enhancement Recommendations (6 cards), Data Collection Action Plan timeline"
    },
    {
      "id": "data-center",
      "label": "Data Center",
      "icon": "Upload",
      "section": "System",
      "badge": "NEW",
      "description": "Data management hub: Database Status Bar (9 categories), One-Click Seed, 6 CSV Upload Zones, Manual Input Form, Upload History table"
    }
  ],
