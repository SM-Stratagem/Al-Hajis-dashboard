  "data_layer": {
    "description": "Custom React hook useStoreData() fetches from 5 API endpoints in parallel on mount, transforms API responses into the same shape as hardcoded constants, computes all derived metrics, falls back to hardcoded data if API fails",
    "interface_StoreData": {
      "months": "string[]",
      "monthsFull": "string[]",
      "gross": "number[]",
      "returns": "number[]",
      "net": "number[]",
      "cash": "number[]",
      "card": "number[]",
      "daily": "{ startDay: number; values: number[] }[]",
      "capexItems": "{ name: string; amount: number; category: string }[]",
      "overheads": "{ name: string; amount: number }[]",
      "pnl": "P&L period object with expenses array",
      "totalGross": "number",
      "totalNet": "number",
      "totalReturns": "number",
      "totalCash": "number",
      "totalCard": "number",
      "avgMonthlyNet": "number",
      "capitalRecovered": "number",
      "avgReturnRate": "number",
      "cardShare": "number",
      "cumulativeNet": "number[]",
      "returnRates": "number[]",
      "momGrowth": "(number | null)[]",
      "cardPct": "number[]",
      "totalCapex": "number",
      "totalOverheads": "number",
      "totalInvestment": "number",
      "monthlyData": "combined monthly objects for charts",
      "capexByCategory": "grouped CAPEX by category for donut chart"
    },
    "helper_functions": {
      "deriveMetrics": "Computes totals, averages, cumulative net, return rates, MoM growth, card percentages",
      "buildMonthlyData": "Builds combined monthly data objects for Recharts",
      "buildCapexByCategory": "Groups CAPEX items by category"
    }
  },
  "csv_upload_formats": {
    "monthly-sales": {
      "required_columns": ["month", "year", "gross", "returns", "net", "cash", "card"],
      "alt_columns": { "month": ["m"], "year": ["yr", "y"], "gross": ["total_gross"], "returns": ["return_amount"], "net": ["net_revenue"], "cash": ["cash_sales"], "card": ["card_sales", "credit_card"] }
    },
    "capex": {
      "required_columns": ["name", "amount", "category"],
      "alt_columns": { "name": ["item", "description"], "amount": ["cost", "value"], "category": ["type", "cat"] }
    },
    "overheads": {
      "required_columns": ["name", "amount"],
      "alt_columns": { "name": ["item", "description"], "amount": ["cost", "value"] }
    },
    "products": {
      "required_columns": ["name"],
      "optional_columns": ["sku", "category", "unit_cost", "selling_price", "quantity", "revenue", "month", "year"],
      "alt_columns": { "unit_cost": ["cost", "purchase_price"], "selling_price": ["price", "sale_price"], "quantity": ["qty", "units_sold"], "revenue": ["total", "sales"] }
    },
    "transactions": {
      "required_columns": ["month", "year", "receipts", "revenue"],
      "alt_columns": { "month": ["m"], "year": ["yr", "y"], "receipts": ["transactions"], "revenue": ["total"] }
    }
  },
