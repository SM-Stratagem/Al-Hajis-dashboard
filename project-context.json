{
  "project_name": "Parfumix ADCB Branch Intelligence Dashboard",
  "project_description": "A comprehensive real-time analytics dashboard for Parfumix perfume retail kiosk located in ADCB Mall, Dubai, UAE. Built with Next.js 16 App Router, single-page architecture with sidebar navigation, dark luxury theme, and live database connectivity.",
  "business_context": {
    "business_name": "Parfumix ADCB",
    "location": "ADCB Mall, Dubai, UAE",
    "type": "Perfume retail kiosk",
    "currency": "AED",
    "data_period": "October 2025 – March 2026 (6 months verified)",
    "pnl_period": "September 2025 – December 2025",
    "total_investment": 532211,
    "gross_margin_verified": "73.10%",
    "key_insight": "Key money (AED 190K) is 35.7% of total investment and is a non-recoverable sunk cost"
  },
  "tech_stack": {
    "framework": "Next.js 16 with App Router",
    "language": "TypeScript 5",
    "styling": "Tailwind CSS 4 with shadcn/ui components (New York style)",
    "charts": "Recharts 2.15",
    "database": "Prisma ORM with SQLite (client only)",
    "state_management": "React useState + custom useStoreData hook",
    "icons": "Lucide React",
    "fonts": "Geist + Geist Mono (system)",
    "key_packages": [
      "recharts", "prisma", "@prisma/client", "lucide-react",
      "framer-motion", "zustand", "@tanstack/react-query", "next-auth"
    ]
  },
  "architecture": {
    "pattern": "Single-page app with client-side tab navigation",
    "data_flow": "SQLite DB → API Routes → useStoreData() hook → Page Components",
    "file_structure": {
      "src/app/page.tsx": "Main dashboard file (3177 lines) — all 15 page components, sidebar, navigation, data layer",
      "src/app/globals.css": "Global styles with dark luxury theme variables",
      "src/app/layout.tsx": "Next.js layout wrapper",
      "src/lib/data.ts": "Hardcoded fallback data constants (145 lines)",
      "src/lib/seed-data.ts": "Seed data for database initialization (89 lines)",
      "src/lib/csv-parser.ts": "CSV parser utility (113 lines)",
      "src/lib/db.ts": "Prisma client singleton",
      "src/lib/utils.ts": "Utility functions (cn, etc.)",
      "prisma/schema.prisma": "Database schema (11 models)",
      "db/custom.db": "SQLite database file"
    },
    "api_routes": {
      "GET /api/data/status": "Returns data counts, hasData flags, recent uploads",
      "POST /api/data/seed": "Seeds database with existing Parfumix data (confirm: true)",
      "DELETE /api/data/reset": "Clears all data from database",
      "POST /api/data/upload": "Uploads CSV file (FormData with file + category)",
      "GET|POST|DELETE /api/data/monthly-sales": "Monthly sales CRUD",
      "GET|POST /api/data/daily-sales": "Daily sales CRUD",
      "GET|POST|DELETE /api/data/capex": "CAPEX items CRUD",
      "GET|POST /api/data/overheads": "Overheads CRUD",
      "GET|POST|DELETE /api/data/pnl": "P&L periods CRUD (with nested expenses)",
      "GET|POST|DELETE /api/data/products": "Product/SKU sales CRUD",
      "GET|POST /api/data/staff-costs": "Staff costs CRUD",
      "GET|POST /api/data/marketing": "Marketing spend CRUD",
      "GET|POST /api/data/transactions": "Transaction summaries CRUD"
    }
  },
  "database_schema": {
    "models": [
      {
        "name": "Branch",
        "fields": ["id", "name", "location", "currency", "createdAt", "updatedAt"]
      },
      {
        "name": "MonthlySale",
        "fields": ["id", "month (Int)", "year (Int)", "gross (Float)", "returns (Float)", "net (Float)", "cash (Float)", "card (Float)"],
        "relations": ["dailySales", "staffCosts", "marketingSpends", "transactions"],
        "unique": ["month, year"]
      },
      {
        "name": "DailySale",
        "fields": ["id", "date (String YYYY-MM-DD)", "dayOfWeek (Int 0=Sun)", "revenue (Float)", "month (Int)", "year (Int)"],
        "relations": ["monthlySale"],
        "unique": ["date"]
      },
      {
        "name": "CapexItem",
        "fields": ["id", "name", "amount (Float)", "category (String: Lease|Fit-out|Inventory|Tech|Legal|Deposits|People|Other)"]
      },
      {
        "name": "Overhead",
        "fields": ["id", "name", "amount (Float)"]
      },
      {
        "name": "PnlPeriod",
        "fields": ["id", "period", "revenue", "cogsGoods", "cogsAccessories", "totalCogs", "grossProfit", "grossMargin", "totalExpenses", "netProfitLoss"],
        "relations": ["expenses (PnlExpense[])"]
      },
      {
        "name": "PnlExpense",
        "fields": ["id", "name", "amount", "pnlPeriodId"],
        "relations": ["pnlPeriod"]
      },
      {
        "name": "ProductSale",
        "fields": ["id", "name", "sku", "category", "unitCost", "sellingPrice", "quantitySold", "revenue", "margin", "month?", "year?"]
      },
      {
        "name": "StaffCost",
        "fields": ["id", "month", "year", "salary", "commission", "visa", "accommodation", "overtime", "other", "total"],
        "relations": ["monthlySale"],
        "unique": ["month, year"]
      },
      {
        "name": "MarketingSpend",
        "fields": ["id", "month", "year", "channel", "amount", "notes?"],
        "relations": ["monthlySale"]
      },
      {
        "name": "TransactionSummary",
        "fields": ["id", "month", "year", "receiptCount", "totalRevenue", "avgTicketSize?"],
        "relations": ["monthlySale"],
        "unique": ["month, year"]
      },
      {
        "name": "DataUpload",
        "fields": ["id", "category", "fileName", "rowCount", "status (success|error|partial)", "error?"]
      }
    ]
  },
