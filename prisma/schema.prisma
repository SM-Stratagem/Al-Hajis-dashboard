// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ═══════════════════════════════════════════════════════════════
// BRANCH CONFIGURATION
// ═══════════════════════════════════════════════════════════════

model Branch {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  city      String
  country   String
  flag      String   @default("🇦🇪")
  currency  String   @default("AED")
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  monthlySales      MonthlySale[]
  capexItems        CapexItem[]
  overheads         Overhead[]
  pnlPeriods        PnlPeriod[]
  productSales      ProductSale[]
  supplyItems       SupplyItem[]
  supplyOrders      SupplyOrder[]
  connectors        Connector[]
}

// ═══════════════════════════════════════════════════════════════
// MONTHLY SALES (from POS daywise reports)
// ═══════════════════════════════════════════════════════════════

model MonthlySale {
  id        String   @id @default(cuid())
  month     Int      // 1-12
  year      Int      // e.g. 2025
  gross     Float
  returns   Float    @default(0)
  net       Float
  cash      Float    @default(0)
  card      Float    @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  branchId   String
  branch     Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  dailySales    DailySale[]
  staffCosts    StaffCost[]
  marketingSpends MarketingSpend[]
  transactions  TransactionSummary[]

  @@unique([month, year, branchId])
}

// ═══════════════════════════════════════════════════════════════
// DAILY SALES (per day revenue)
// ═══════════════════════════════════════════════════════════════

model DailySale {
  id        String   @id @default(cuid())
  date      String   // "YYYY-MM-DD"
  dayOfWeek Int      // 0=Sun, 1=Mon, ..., 6=Sat
  revenue   Float
  month     Int
  year      Int
  createdAt DateTime @default(now())

  monthlySaleId String
  monthlySale   MonthlySale @relation(fields: [monthlySaleId], references: [id], onDelete: Cascade)

  @@unique([date, monthlySaleId])
}

// ═══════════════════════════════════════════════════════════════
// CAPEX ITEMS
// ═══════════════════════════════════════════════════════════════

model CapexItem {
  id       String  @id @default(cuid())
  name     String
  amount   Float
  category String  // Lease, Fit-out, Inventory, Tech, Legal, Deposits, People, Other

  branchId String
  branch   Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)
}

// ═══════════════════════════════════════════════════════════════
// OVERHEADS (pre-launch costs)
// ═══════════════════════════════════════════════════════════════

model Overhead {
  id     String @id @default(cuid())
  name   String
  amount Float

  branchId String
  branch   Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)
}

// ═══════════════════════════════════════════════════════════════
// P&L PERIODS
// ═══════════════════════════════════════════════════════════════

model PnlPeriod {
  id           String   @id @default(cuid())
  period       String   // "Sep 2025 – Dec 2025"
  revenue      Float
  cogsGoods    Float    @default(0)
  cogsAccessories Float  @default(0)
  totalCogs    Float    @default(0)
  grossProfit  Float
  grossMargin  Float
  totalExpenses Float
  netProfitLoss Float
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  branchId String
  branch   Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  expenses PnlExpense[]
}

// ═══════════════════════════════════════════════════════════════
// P&L EXPENSE LINE ITEMS
// ═══════════════════════════════════════════════════════════════

model PnlExpense {
  id         String   @id @default(cuid())
  name       String
  amount     Float
  createdAt  DateTime @default(now())

  pnlPeriodId String
  pnlPeriod   PnlPeriod @relation(fields: [pnlPeriodId], references: [id], onDelete: Cascade)
}

// ═══════════════════════════════════════════════════════════════
// PRODUCT / SKU SALES
// ═══════════════════════════════════════════════════════════════

model ProductSale {
  id          String   @id @default(cuid())
  name        String
  sku         String?
  category    String   // Oud, Floral, Fresh, Oriental, Accessories, etc.
  unitCost    Float    @default(0)
  sellingPrice Float   @default(0)
  quantitySold Int     @default(0)
  revenue     Float
  margin      Float?
  month       Int?
  year        Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  branchId String
  branch   Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)
}

// ═══════════════════════════════════════════════════════════════
// STAFF COSTS (monthly)
// ═══════════════════════════════════════════════════════════════

model StaffCost {
  id           String @id @default(cuid())
  month        Int
  year         Int
  salary       Float  @default(0)
  commission   Float  @default(0)
  visa         Float  @default(0)
  accommodation Float @default(0)
  overtime     Float  @default(0)
  other        Float  @default(0)
  total        Float

  monthlySaleId String
  monthlySale   MonthlySale @relation(fields: [monthlySaleId], references: [id], onDelete: Cascade)

  @@unique([month, year, monthlySaleId])

  @@index([monthlySaleId])
}

// ═══════════════════════════════════════════════════════════════
// MARKETING SPEND (monthly by channel)
// ═══════════════════════════════════════════════════════════════

model MarketingSpend {
  id            String  @id @default(cuid())
  month         Int
  year          Int
  channel       String  // Instagram, In-mall, Flyers, Influencers, etc.
  amount        Float
  notes         String?

  monthlySaleId String
  monthlySale   MonthlySale @relation(fields: [monthlySaleId], references: [id], onDelete: Cascade)

  @@index([monthlySaleId])
}

// ═══════════════════════════════════════════════════════════════
// TRANSACTION SUMMARY (daily/monthly aggregates)
// ═══════════════════════════════════════════════════════════════

model TransactionSummary {
  id            String @id @default(cuid())
  month         Int
  year          Int
  receiptCount  Int    @default(0)
  totalRevenue  Float
  avgTicketSize Float?

  monthlySaleId String
  monthlySale   MonthlySale @relation(fields: [monthlySaleId], references: [id], onDelete: Cascade)

  @@unique([month, year, monthlySaleId])

  @@index([monthlySaleId])
}

// ═══════════════════════════════════════════════════════════════
// UPLOAD HISTORY
// ═══════════════════════════════════════════════════════════════

model DataUpload {
  id        String   @id @default(cuid())
  branchId  String?
  category  String   // monthly-sales, daily-sales, capex, overheads, pnl, products, staff-costs, marketing, transactions, seed
  fileName  String
  rowCount  Int      @default(0)
  status    String   @default("success") // success, error, partial
  error     String?
  createdAt DateTime @default(now())
}

// ═══════════════════════════════════════════════════════════════
// SUPPLY CHAIN — STOCK ON HAND (SOH)
// ═══════════════════════════════════════════════════════════════

model SupplyItem {
  id             String   @id @default(cuid())
  itemId         String   @unique
  itemName       String
  category       String   // Oil, Alcohol, Combiner, Accessories
  currentQtyL    Float    @default(0)
  minThresholdL  Float    @default(0)
  unitCostAED    Float    @default(0)
  supplierId     String?
  supplierName   String?
  lastUpdated    DateTime @default(now())
  lastSoldDate   String?  // ISO date of last sale (for slow-moving detection)

  branchId       String
  branch         Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)

  consumptions   SupplyConsumption[]
  orderLines     SupplyOrderLine[]

  @@index([branchId, category])
}

// ═══════════════════════════════════════════════════════════════
// SUPPLY CHAIN — PURCHASE CONSUMPTION RECORDS
// ═══════════════════════════════════════════════════════════════

model SupplyConsumption {
  id            String   @id @default(cuid())
  date          String   // "YYYY-MM-DD"
  qtyUsedL      Float
  staffCode     String?
  transactionType String @default("sale") // sale, blending, wastage

  supplyItemId  String
  supplyItem    SupplyItem @relation(fields: [supplyItemId], references: [id], onDelete: Cascade)

  createdAt     DateTime @default(now())

  @@index([supplyItemId, date])
}

// ═══════════════════════════════════════════════════════════════
// SUPPLY CHAIN — ORDER FORMS
// ═══════════════════════════════════════════════════════════════

model SupplyOrder {
  id             String   @id @default(cuid())
  orderId        String   @unique  // "ORD-XXXX"
  branchId       String
  branchName     String
  dateCreated    DateTime @default(now())
  deliveryRequested String?
  generatedBy    String   @default("AI") // "AI" or staff code
  orderTotalAED  Float    @default(0)
  status         String   @default("draft") // draft, submitted, approved, delivered, partial
  notes          String?

  branch         Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)

  lineItems      SupplyOrderLine[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([branchId, status])
  @@index([orderId])
}

// ═══════════════════════════════════════════════════════════════
// SUPPLY CHAIN — ORDER LINE ITEMS
// ═══════════════════════════════════════════════════════════════

model SupplyOrderLine {
  id             String   @id @default(cuid())
  itemId         String
  itemName       String
  category       String
  currentSohL    Float
  orderQtyL      Float
  unitCostAED    Float
  lineTotalAED   Float
  priority       String   // CRITICAL, LOW, OPTIONAL
  supplierLeadDays Int    @default(3)
  urgent         Boolean  @default(false)

  supplyItemId   String?
  supplyItem     SupplyItem? @relation(fields: [supplyItemId], references: [id])

  supplyOrderId  String
  supplyOrder    SupplyOrder @relation(fields: [supplyOrderId], references: [id], onDelete: Cascade)

  @@index([supplyOrderId])
}

// ═══════════════════════════════════════════════════════════════
// INTEGRATIONS — CONNECTOR REGISTRY
// ═══════════════════════════════════════════════════════════════

model Connector {
  id          String   @id @default(cuid())
  name        String   // "Magnati POS - ADCB"
  type        String   // pos, erp, google_sheets, custom, webhook
  system      String   // magnati, sap, odoo, square, zoho, sheets, custom
  branchId    String?
  branch      Branch?  @relation(fields: [branchId], references: [id], onDelete: SetNull)

  enabled     Boolean  @default(false)
  config      String   @default("{}") // JSON: API keys, endpoints, credentials (encrypted in prod)
  fieldMap    String   @default("{}") // JSON: external field → internal field mapping

  lastSyncAt  DateTime?
  lastStatus  String   @default("never") // never, success, error, partial
  lastError   String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  syncLogs    SyncLog[]

  @@index([type, enabled])
  @@index([branchId])
}

// ═══════════════════════════════════════════════════════════════
// INTEGRATIONS — SYNC LOG / AUDIT TRAIL
// ═══════════════════════════════════════════════════════════════

model SyncLog {
  id            String   @id @default(cuid())
  connectorId   String
  connector     Connector @relation(fields: [connectorId], references: [id], onDelete: Cascade)

  direction     String   @default("inbound") // inbound, outbound
  category      String   // sales, inventory, staff, products, supply-chain, transactions
  method        String   // push, pull, webhook, manual
  recordCount   Int      @default(0)
  status        String   @default("success") // success, error, partial
  errorMessage  String?
  durationMs    Int      @default(0)

  // Store a small summary of what was synced (not the full payload)
  summary       String?

  createdAt     DateTime @default(now())

  @@index([connectorId, createdAt])
  @@index([category])
}
